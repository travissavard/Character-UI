  "description": "Shared per-user filesystem persistence for Character UI local adapters.",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/travissavard/Character-UI.git",
    "directory": "packages/local-storage"
  },
  "homepage": "https://travissavard.github.io/Character-UI/",
