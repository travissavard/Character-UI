{
  "name": "@character-ui/core",
  "version": "0.1.0",
  "description": "Schemas, defaults, validation, and deterministic compilation for Character UI.",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/travissavard/Character-UI.git",
    "directory": "packages/core"
  },
  "homepage": "https://travissavard.github.io/Character-UI/",
  "bugs": {
    "url": "https://github.com/travissavard/Character-UI/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "TRAITS_LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^4.0.0"
  }
}
